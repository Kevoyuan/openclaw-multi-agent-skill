# claw-agents example configuration overrides
#
# Copy values into your shell profile or export them before running scripts.

# Force prompt language: en or zh
# CLAW_AGENTS_LANG=en

# Override the OpenClaw state directory
# OPENCLAW_STATE_DIR=$HOME/.openclaw

# Override the config file path directly
# OPENCLAW_CONFIG_PATH=$HOME/.openclaw/openclaw.json
